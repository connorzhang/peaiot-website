{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "voc-method.v1.schema.json",
  "title": "voc-method.v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "methodId", "version", "pollutants"],
  "properties": {
    "schema": { "const": "voc-method.v1" },
    "methodId": { "type": "string", "format": "uuid" },
    "version": { "type": "integer", "minimum": 1 },
    "pollutants": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "code",
          "name",
          "startS",
          "endS",
          "paddingS",
          "alignMode",
          "baselineMode",
          "threshold"
        ],
        "properties": {
          "code": { "type": "string", "minLength": 1, "maxLength": 32 },
          "name": { "type": "string", "minLength": 1, "maxLength": 64 },
          "startS": { "type": "number", "minimum": 0 },
          "endS": { "type": "number", "minimum": 0 },
          "paddingS": { "type": "number", "minimum": 0 },
          "alignMode": { "type": "string", "enum": ["none", "peakmax"] },
          "baselineMode": { "type": "string", "enum": ["linear_endpoints"] },
          "threshold": { "type": "number", "minimum": 0 }
        }
      }
    }
  }
}

