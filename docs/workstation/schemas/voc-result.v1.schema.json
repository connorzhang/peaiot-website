{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "voc-result.v1.schema.json",
  "title": "voc-result.v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "traceId",
    "deviceId",
    "stationId",
    "methodId",
    "methodVersion",
    "createdAt",
    "engine",
    "pollutants"
  ],
  "properties": {
    "schema": { "const": "voc-result.v1" },
    "traceId": { "type": "string", "format": "uuid" },
    "deviceId": { "type": "string", "minLength": 1, "maxLength": 32 },
    "stationId": { "type": "string", "minLength": 24, "maxLength": 24 },
    "methodId": { "type": "string", "format": "uuid" },
    "methodVersion": { "type": "integer", "minimum": 1 },
    "createdAt": { "type": "string", "format": "date-time" },
    "engine": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "version", "gitSha"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "version": { "type": "string", "minLength": 1 },
        "gitSha": { "type": "string", "minLength": 1 }
      }
    },
    "pollutants": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["code", "name", "status", "rtS", "area", "height"],
        "properties": {
          "code": { "type": "string", "minLength": 1, "maxLength": 32 },
          "name": { "type": "string", "minLength": 1, "maxLength": 64 },
          "status": { "type": "string", "enum": ["detected", "not_detected"] },
          "rtS": { "type": "number", "minimum": 0 },
          "area": { "type": "number", "minimum": 0 },
          "height": { "type": "number", "minimum": 0 }
        }
      }
    }
  }
}

