{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "voc-trace.v1.schema.json",
  "title": "voc-trace.v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "traceId",
    "deviceId",
    "stationId",
    "dataTime",
    "timeSpanS",
    "dtS",
    "unit",
    "values"
  ],
  "properties": {
    "schema": { "const": "voc-trace.v1" },
    "traceId": { "type": "string", "format": "uuid" },
    "deviceId": { "type": "string", "minLength": 1, "maxLength": 32 },
    "stationId": { "type": "string", "minLength": 24, "maxLength": 24 },
    "dataTime": { "type": "string", "format": "date-time" },
    "timeSpanS": { "type": "number", "exclusiveMinimum": 0 },
    "dtS": { "type": "number", "exclusiveMinimum": 0 },
    "unit": { "type": "string", "minLength": 1 },
    "values": {
      "type": "array",
      "minItems": 2,
      "items": { "type": "number" }
    }
  }
}

