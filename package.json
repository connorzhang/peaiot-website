{
  "name": "rspress-doc-template",
  "version": "1.0.3",
  "private": true,
  "type": "module",
  "scripts": {
    "predev:doc": "node scripts/generate-project-index.js",
    "prebuild:doc": "node scripts/generate-project-index.js",
    "dev:www": "rspress dev -c rspress.www.config.ts",
    "dev:doc": "rspress dev -c rspress.doc.config.ts",
    "build:www": "rspress build -c rspress.www.config.ts",
    "build:doc": "rspress build -c rspress.doc.config.ts",
    "build:all": "npm run build:www && npm run build:doc",
    "preview:www": "rspress preview -c rspress.www.config.ts",
    "preview:doc": "rspress preview -c rspress.doc.config.ts"
  },
  "dependencies": {
    "@rspress/core": "^2.0.12",
    "clsx": "^2.1.1",
    "dotenv": "^17.4.2",
    "framer-motion": "^12.40.0",
    "lucide-react": "^1.17.0",
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
    "@types/node": "^22.8.1",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.5.0",
    "postcss": "^8.5.15",
    "postcss-loader": "^8.2.1",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "tailwindcss": "^3.4.19"
  }
}
